generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum ActorRole {
  Blacksmith
  Guard
  Alchemist
  Innkeeper
  Adventurer
  Merchant
  Mayor

  @@map("actor_roles")
}

enum ActionType {
  // Generics
  Kill
  Gather
  Escort
  Investigate
  Betray
  Negotiate
  Intimidate
  Trade
  Heal
  Deliver
  Survive
  Destroy
  Steal
  Rescue
  Protect
  Spy
  Flee
  Recruit
  Sabotage
  // Warrior
  Challenge
  Siege
  Guard
  Execute
  Rally
  // Mage
  Ritual
  Banish
  Decipher
  Enchant
  Contain
  // Rogue
  Infiltrate
  Assassinate
  Forge
  Blackmail
  Pickpocket
  // Cleric
  Purify
  Consecrate
  Exorcise
  LastRites
  Convert

  @@map("action_types")
}

enum HeroClass {
  Warrior
  Rogue
  Mage
  Cleric
}

enum QuestStatus {
  Available
  Accepted
  Completed
  Failed
}

enum TargetCategory {
  Monster
  Person
  Item
  Location
  // Targets específicos de classe
  Mage
  Warrior
  Rogue
  Cleric
}

model Target {
  id         String         @id @default(uuid())
  name       String
  category   TargetCategory
  level      Int
  objectives Objective[]

  @@map("targets")
}

model Hero {
  id         String    @id @default(uuid())
  name       String
  class      HeroClass
  level      Int       @default(1)
  experience Int       @default(0)
  gold       Int       @default(0)
  reputation Int       @default(0)
  quests     Quest[]

  @@map("heroes")
}

model Actor {
  id        String    @id @default(uuid())
  name      String
  role      ActorRole
  level     Int
  hostility Boolean
  quests    Quest[]

  @@map("actors")
}

model Objective {
  id       String     @id @default(uuid())
  action   ActionType
  quantity Int
  target   Target     @relation(fields: [targetId], references: [id])
  targetId String     @map("target_id")
  quest    Quest      @relation(fields: [questId], references: [id])
  questId  String     @map("quest_id")

  @@map("objectives")
}

model Quest {
  id          String      @id @default(uuid())
  title       String
  description String
  actor       Actor       @relation(fields: [actorId], references: [id])
  actorId     String      @map("actor_id")
  objectives  Objective[]
  goldReward  Int         @map("gold_reward")
  xpReward    Int         @map("xp_reward")
  hero        Hero        @relation(fields: [heroId], references: [id])
  heroId      String      @map("hero_id")
  status      QuestStatus @default(Available)

  @@map("quests")
}
